#!/bin/sh
# Auto-update the SW cache version by hashing all HTML/CSS/JS content.
# Forces the service worker to reinstall and re-crawl whenever any
# page, stylesheet, or script changes.

HASH=$(find . \( -name "*.html" -o -name "*.css" -o -name "*.js" \) \
  ! -path "./.git/*" ! -name "sw.js" | sort | xargs cat 2>/dev/null \
  | shasum | cut -c1-8)

sed -i '' "s/const CACHE = 'travel-[^']*'/const CACHE = 'travel-$HASH'/" sw.js
git add sw.js
